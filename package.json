{
	"name": "billboard.js",
	"version": "4.0.1",
	"description": "Re-usable easy interface JavaScript chart library, based on D3 v4+",
	"homepage": "https://naver.github.io/billboard.js/",
	"main": "dist/billboard.js",
	"module": "dist-esm/index.esm.js",
	"types": "types/index.d.ts",
	"typesVersions": {
		"*": {
			"canvas": [
				"types/canvas.d.ts"
			]
		}
	},
	"type": "module",
	"exports": {
		".": {
			"types": "./types/index.d.ts",
			"import": "./dist-esm/index.esm.js",
			"require": "./dist/billboard.pkgd.js"
		},
		"./canvas": {
			"types": "./types/canvas.d.ts",
			"import": "./dist-esm/index.canvas.js",
			"require": "./dist/billboard.pkgd.js"
		},
		"./dist/plugin/*": {
			"types": "./types/plugin/*.d.ts",
			"import": "./dist-esm/plugin/*.js",
			"require": "./dist/plugin/pkgd/*.js"
		},
		"./dist/*": "./dist/*",
		"./src/Plugin/*": "./src/Plugin/*.js"
	},
	"scripts": {
		"start": "webpack serve --open",
		"start:plugin": "cross-env PLUGIN=true webpack-dev-server --open",
		"build": "pnpm run build:production && pnpm run build:packaged && pnpm run build:theme && pnpm run build:plugin && pnpm run build:esm && pnpm run build:cjs && pnpm run build:plugin:types",
		"build:cjs": "node ./config/cjs.js",
		"build:esm": "rollup -c ./config/rollup/esm.js",
		"build:production": "cross-env NODE_ENV=production webpack",
		"build:packaged": "cross-env NODE_ENV=packaged webpack",
		"build:dev": "cross-env NODE_ENV=development webpack",
		"build:theme": "cross-env NODE_ENV=theme webpack",
		"build:production:analyzer": "cross-env ANALYZER=true pnpm run build:production",
		"build:packaged:analyzer": "cross-env ANALYZER=true pnpm run build:packaged",
		"build:plugin": "cross-env NODE_ENV=plugin webpack && cross-env NODE_ENV=plugin MODE=min webpack && cross-env NODE_ENV=plugin MODE=pkgd webpack && cross-env NODE_ENV=plugin MODE=pkgd-min webpack",
		"build:plugin:types": "node ./config/type.d-plugin.js",
		"release": "semantic-release",
		"lint": "eslint",
		"format": "dprint fmt",
		"loc": "cloc --by-file src",
		"test": "vitest",
		"coverage": "vitest run",
		"coverage:ci": "cross-env NODE_ENV=CI vitest run",
		"jsdoc": "node ./config/jsdoc.js",
		"jsdoc:cmd": "jsdoc -c jsdoc.json",
		"lint-staged": "lint-staged --config ./config/.lintstagedrc.json",
		"prepare": "husky"
	},
	"sideEffects": [
		"dist/**/*.css",
		"dist-esm/Chart/api/stubs.js",
		"src/Chart/api/stubs.ts",
		"src/index.ts"
	],
	"repository": {
		"type": "git",
		"url": "git+https://github.com/naver/billboard.js.git"
	},
	"bugs": {
		"url": "https://github.com/naver/billboard.js/issues"
	},
	"keywords": [
		"d3",
		"chart",
		"graph",
		"svg"
	],
	"files": [
		"dist",
		"dist-esm",
		"src",
		"types",
		"CONTRIBUTING.md"
	],
	"npmName": "billboard.js",
	"npmFileMap": [
		{
			"basePath": "dist",
			"files": [
				"**/*"
			]
		}
	],
	"author": "NAVER Corp.",
	"license": "MIT",
	"readmeFilename": "README.md",
	"dependencies": {
		"@types/d3-selection": "^3.0.11",
		"@types/d3-transition": "^3.0.9",
		"d3-axis": "^3.0.0",
		"d3-brush": "^3.0.0",
		"d3-drag": "^3.0.0",
		"d3-hierarchy": "^3.1.2",
		"d3-interpolate": "^3.0.1",
		"d3-scale": "^4.0.2",
		"d3-selection": "^3.0.0",
		"d3-shape": "^3.2.0",
		"d3-time-format": "^4.1.0",
		"d3-transition": "^3.0.1",
		"d3-zoom": "^3.0.0"
	},
	"devDependencies": {
		"@commitlint/cli": "^21.0.2",
		"@commitlint/config-conventional": "^21.0.2",
		"@eslint/js": "^10.0.1",
		"@playwright/test": "^1.61.0",
		"@rollup/plugin-node-resolve": "^16.0.3",
		"@rollup/plugin-replace": "^6.0.3",
		"@rollup/plugin-typescript": "^12.3.0",
		"@semantic-release/changelog": "^6.0.3",
		"@semantic-release/commit-analyzer": "^13.0.1",
		"@semantic-release/exec": "^7.1.0",
		"@semantic-release/git": "^10.0.1",
		"@semantic-release/npm": "^13.1.5",
		"@semantic-release/release-notes-generator": "^14.1.1",
		"@testing-library/dom": "^10.4.1",
		"@testing-library/react": "^16.3.2",
		"@types/d3": "^7.4.3",
		"@types/sinon": "^21.0.1",
		"@vitest/browser": "^4.1.9",
		"@vitest/browser-playwright": "^4.1.9",
		"@vitest/coverage-istanbul": "^4.1.9",
		"@vitest/ui": "^4.1.9",
		"better-docs": "^2.7.3",
		"clean-webpack-plugin": "^4.0.0",
		"cloc": "2.6.0-cloc",
		"core-js": "^3.49.0",
		"cross-env": "^10.1.0",
		"css-loader": "^7.1.4",
		"d3-delaunay": "^6.0.4",
		"d3-format": "^3.1.2",
		"d3-time": "^3.1.0",
		"docdash": "^2.0.2",
		"dprint": "^0.54.0",
		"esbuild-loader": "^4.5.0",
		"eslint": "^10.5.0",
		"eslint-plugin-import": "^2.32.0",
		"eslint-plugin-jsdoc": "^63.0.6",
		"husky": "^9.1.7",
		"jsdoc": "^4.0.5",
		"lint-staged": "^17.0.7",
		"mini-css-extract-plugin": "^2.10.2",
		"playwright": "^1.61.0",
		"regenerator-runtime": "^0.14.1",
		"rollup": "^4.62.0",
		"rollup-plugin-delete": "^3.0.2",
		"sass": "^1.101.0",
		"sass-loader": "^17.0.0",
		"semantic-release": "^25.0.5",
		"simulant": "^0.2.2",
		"sinon": "^22.0.0",
		"string-replace-loader": "^3.3.0",
		"style-loader": "^4.0.0",
		"tslib": "^2.8.1",
		"typescript": "^6.0.3",
		"typescript-eslint": "^8.61.1",
		"vitest": "^4.1.9",
		"webpack": "^5.107.2",
		"webpack-bundle-analyzer": "^5.3.0",
		"webpack-clean": "^1.2.5",
		"webpack-cli": "^7.0.3",
		"webpack-dev-server": "^5.2.5",
		"webpack-merge": "^6.0.1",
		"webpackbar": "^7.0.0",
		"write-file-webpack-plugin": "^4.5.1"
	},
	"packageManager": "pnpm@10.16.0"
}

{
	"name": "@billboard.js/react",
	"version": "1.1.1",
	"description": "React component for billboard.js",
	"main": "dist/billboardjs-react.js",
	"types": "dist/types/index.d.ts",
	"type": "module",
	"exports": {
		".": {
			"types": "./dist/types/index.d.ts",
			"import": "./dist/billboardjs-react.js",
			"require": "./dist/billboardjs-react.cjs"
		}
	},
	"scripts": {
		"dev": "vite",
		"build": "tsc && vite build && tsc --emitDeclarationOnly",
		"build:test": "vite --config vite.config.test.ts build",
		"preview": "pnpm run build:test && vite preview",
		"test": "pnpm run build:test && vitest",
		"test:ui": "pnpm run test -- --ui",
		"coverage": "pnpm run build:test && vitest run",
		"storybook": "start-storybook -p 6006",
		"build-storybook": "build-storybook",
		"deploy": "pnpm run coverage && pnpm run build"
	},
	"repository": {
		"type": "git",
		"url": "https://github.com/naver/billboard.js/tree/master/packages/react"
	},
	"keywords": [
		"billboard.js",
		"chart",
		"graph",
		"react",
		"svg"
	],
	"files": [
		"dist",
		"src",
		"README.md"
	],
	"author": "NAVER Corp.",
	"license": "MIT",
	"readmeFilename": "README.md",
	"peerDependencies": {
		"billboard.js": ">=3.0.0",
		"react": ">=16.8.0"
	},
	"devDependencies": {
		"@babel/core": "^8.0.1",
		"@playwright/test": "^1.61.0",
		"@storybook/addon-actions": "^9.0.8",
		"@storybook/addon-console": "^3.0.0",
		"@storybook/addon-essentials": "^8.6.14",
		"@storybook/addon-interactions": "^8.6.14",
		"@storybook/addon-links": "^10.4.6",
		"@storybook/builder-vite": "^10.4.6",
		"@storybook/react": "^10.4.6",
		"@storybook/testing-library": "^0.2.2",
		"@types/react": "^19.2.17",
		"@types/react-dom": "^19.2.3",
		"@vitejs/plugin-react": "^6.0.2",
		"@vitest/coverage-c8": "^0.33.0",
		"@vitest/coverage-istanbul": "4.1.9",
		"@vitest/coverage-v8": "^4.1.9",
		"@vitest/ui": "^4.1.9",
		"babel-loader": "^10.1.1",
		"billboard.js": "^4.0.1",
		"jsdom": "^29.1.1",
		"playwright": "^1.61.0",
		"react": "^19.2.7",
		"react-dom": "^19.2.7",
		"typescript": "^6.0.3",
		"vite": "^8.0.16",
		"vitest": "^4.1.9"
	},
	"packageManager": "pnpm@10.16.0"
}
